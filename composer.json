{
  "name": "turkeryildirim/phpunit-json-coverage-report",
  "description": "Comprehensive JSON coverage reporter for PHPUnit.",
  "type": "library",
  "license": "MIT",
    "keywords": [
        "php",
        "phpuint",
        "code-coverage",
        "coverage",
        "json",
        "reporter"
    ],
    "authors": [
        {
            "name": "Türker Yıldırım",
            "email": "me@turkeryildirim.com",
            "homepage": "https://turkeryildirim.com/"
        }
    ],
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "require": {
        "php": "^8.1",
        "phpunit/php-code-coverage": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "phpunit/phpunit": "^10.0 || ^11.0 || ^12.0 || ^13.0"
    },
  "autoload": {
    "psr-4": {
      "Turker\\PHPUnitCoverageReporter\\": "src/"
    }
  },
      "autoload-dev": {
        "psr-4": {
            "Turker\\PHPUnitCoverageReporter\\Tests\\": "tests/"
        }
    },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "scripts": {
    "test": "phpunit --no-coverage",
    "test-compat": "php tests/test-compat.php"
  },
  "require-dev": {
    "ext-mbstring": "*",
    "ext-simplexml": "*"
  }
}
